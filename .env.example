# Prompt Studio environment — copy to .env (gitignored) and fill in what you use.
# server.py loads .env at boot; scripts read the process environment.
# Every value below is a placeholder; NO real secrets belong in this template.

# ── Required for frontier-model features ─────────────────────────────
# Claude chat proxy (Deliberate view) + scripts/evaluate_prompt.py
ANTHROPIC_API_KEY=sk-ant-...

# Optional: other chat-proxy providers (only if you select these models)
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...
# GEMINI_API_KEY=...

# ── Optional overrides (sensible defaults shown) ─────────────────────
# PORT=8000                     # server.py listen port
# DB_PATH=prompt_studio.db      # SQLite database
# ALLOWED_ORIGIN=http://localhost:7777   # CORS allowlist, comma-separated
# LM_STUDIO_URL=                # browser-addressed LM Studio endpoint
# CLISTA_CLI=~/ClisTa-Protocol/src/cli.js  # ClisTa CLI used for sealing
# THREADHUB_PORT=8110           # local ThreadHub sidecar port

# ── Public front door (skeptic/objection surface) ───────────────────
# STUDIO_PUBLIC_MODE=1          # serve ONLY the skeptic surface (front door)
# STUDIO_OPERATOR_TOKEN=<64-hex>   # gate every state-changing operator route
# STUDIO_PUBLIC_BASE_URL=https://objections.example.com   # base for share/receipt URLs
# THREADHUB_PUBLIC_BASE_URL=https://hub.example.com       # public hub base for receipts
# STUDIO_OBJECT_RATE=10/60      # per-IP rate limit for /object/* (N or N/seconds)

# ── Cloudflare repoint — operator plane drives the cloud Workers ─────
# Set all four to route the operator/seal path at the hosted Workers instead of
# the local sidecar; remove all four to restore the byte-identical local path.
# STUDIO_CLOUD_BASE_URL=https://studio-worker.example.workers.dev
# STUDIO_CLOUD_TOKEN=<64-hex>       # bearer for the studio Worker operator API
# STUDIO_CLOUD_TIMEOUT=15           # per-request timeout (seconds) for cloud calls
# THREADHUB_BASE_URL=https://threadhub-cf.example.workers.dev  # supersedes THREADHUB_PORT
# THREADHUB_WRITE_TOKEN=<64-hex>    # bearer added to every studio->hub write

# ── TLS trust (macOS / python.org Python) ───────────────────────────
# python.org Python ships no CA bundle, so urllib TLS verification of the
# Cloudflare Workers fails (CERTIFICATE_VERIFY_FAILED). Point OpenSSL at the
# system bundle. (certifi's cacert.pem is an alternative path.)
# SSL_CERT_FILE=/etc/ssl/cert.pem
